---
import "../styles/global.css";
const { title } = Astro.props;
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>

<style>

body{
margin:0;
font-family:Arial, sans-serif;
background:#0d0d0d;
color:white;
}

main{
width:100%;
}

h1{
text-align:center;

}

</style>

</head>

<body>

<slot />

</body>

</html>