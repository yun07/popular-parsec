---
const { image, title, link, tags = [] } = Astro.props;
---

<a href={link} class="card">

<img src={image} alt={title} />

<div class="content">

<div class="title">{title}</div>

<div class="tags">
{tags.map(tag => (
<span class="tag">{tag}</span>
))}
</div>

</div>

</a>

<style>

.card{
  display:block;
  background:#111;
  border:1px solid #333;
  transition:0.2s;
}

.card:hover{
  border-color:#666;
}

.card img{
  width:100%;
  display:block;
}

.content{
  padding:0.8rem;
}

.title{
  color:#fff;
  font-weight:600;
  margin-bottom:0.4rem;
}

.tags{
  display:flex;
  flex-wrap:wrap;
  gap:0.3rem;
}

.tag{
  font-size:0.75rem;
  padding:2px 6px;
  border:1px solid #444;
  color:#aaa;
}

</style>