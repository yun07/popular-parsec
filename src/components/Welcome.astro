---
const { title = "Welcome", subtitle = "Tech Art Showreel" } = Astro.props;
---

<section class="welcome">
  <h1>{title}</h1>
  <p>{subtitle}</p>
</section>

<style>
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 4rem 2rem;
  color: #0ff;
}

.welcome h1 {
  font-size: 3rem;
  margin: 0;
  text-shadow: 0 0 5px #0ff, 0 0 10px #0ff, 0 0 20px #0ff;
}

.welcome p {
  font-size: 1.5rem;
  margin-top: 1rem;
  color: #0ff;
  opacity: 0.8;
  text-shadow: 0 0 5px #0ff, 0 0 10px #0ff;
}
</style>