---
import MainLayout from '../layouts/MainLayout.astro'
import Navbar from '../components/Navbar.astro'
import HeroShowreel from '../components/HeroShowreel.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { projects } from '../data/projects.js'
import About from '../components/About.astro'
---

<MainLayout title="Tech Art Portfolio">
<Navbar />

<main>
<HeroShowreel youtubeID="Dxwjx38lV4E" />



<section id="projects" class="projects grid">

{projects.map(p => (
<ProjectCard image={p.image} title={p.title} link={`/projects/${p.slug}`} />
))}

</section>

<About />

</main>

</MainLayout>

<style>

.projects {
  margin-left: auto;
  margin-right: auto;
  max-width: 1800px;
  
  display: grid;
  justify-content: center;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
}

/* 控制最多三列 */
@media (min-width: 960px) { /* 3 * 300px = 900px + gap */
  .projects {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 控制最少兩列 */
@media (max-width: 640px) { /* 2 * 300px = 600px + gap */
  .projects {
    grid-template-columns: repeat(2, 1fr);
  }
}


</style>

